<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="2026_03_04_add_request_portal_id_to_request" author="Ibrahima">
        <addColumn tableName="request">
            <column name="request_portal_id" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_request_request_portal"
                             references="request_portal(id)"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1772773819114-1" author="Ibrahima G. Coulibaly">
        <dropForeignKeyConstraint baseTableName="request" constraintName="fk_request_request_portal"/>
        <addForeignKeyConstraint baseTableName="request" baseColumnNames="request_portal_id"
                                 constraintName="fk_request_request_portal"
                                 referencedTableName="request_portal"
                                 referencedColumnNames="id" onDelete="SET NULL"/>
    </changeSet>
    <changeSet id="1772774718935-1" author="Ibrahima G. Coulibaly">
        <sql>
            insert into subscription_plan_features(subscription_plan_id, features)
            SELECT id, 9
            from subscription_plan
            where code = 'PROFESSIONAL';
        </sql>
    </changeSet>
    <changeSet id="1772891559949-1" author="Ibrahima G. Coulibaly">
        <addColumn tableName="request">
            <column name="contact" type="varchar"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
