<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="2026_05_18_create_product_lifecycle" author="Codex">
        <createTable tableName="product_lifecycle">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="public_id" type="VARCHAR(255)"/>
            <column name="product_uid" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(255)"/>
            <column name="subcategory" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="status" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="serial_number" type="VARCHAR(255)"/>
            <column name="product_version" type="VARCHAR(255)"/>
            <column name="bom_version" type="VARCHAR(255)"/>
            <column name="manufacturing_batch_id" type="VARCHAR(255)"/>
            <column name="manufacturing_date" type="DATE"/>
            <column name="assembly_date" type="DATE"/>
            <column name="qc_status" type="VARCHAR(255)"/>
            <column name="lifecycle_stage" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="model_number" type="VARCHAR(255)"/>
            <column name="part_number" type="VARCHAR(255)"/>
            <column name="mac_address" type="VARCHAR(255)"/>
            <column name="imei_module_id" type="VARCHAR(255)"/>
            <column name="hardware_version" type="VARCHAR(255)"/>
            <column name="firmware_version" type="VARCHAR(255)"/>
            <column name="rfid_tag_id" type="VARCHAR(255)"/>
            <column name="digital_twin_link" type="VARCHAR(255)"/>
            <column name="remarks" type="TEXT"/>
            <column name="assigned_customer" type="VARCHAR(255)"/>
            <column name="installation_site" type="VARCHAR(255)"/>
            <column name="location_gps" type="VARCHAR(255)"/>
            <column name="contact_person" type="VARCHAR(255)"/>
            <column name="contact_number" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="image_url" type="VARCHAR(1000)"/>
            <column name="qr_value" type="TEXT"/>
            <column name="draft" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT"/>
            <column name="updated_by" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="product_lifecycle" baseColumnNames="company_id"
                                 constraintName="fk_product_lifecycle_company" referencedTableName="company"
                                 referencedColumnNames="id" onDelete="CASCADE"/>
        <addUniqueConstraint tableName="product_lifecycle" columnNames="company_id, public_id"
                             constraintName="uk_product_lifecycle_company_public_id"/>
        <addUniqueConstraint tableName="product_lifecycle" columnNames="company_id, product_uid"
                             constraintName="uk_product_lifecycle_company_product_uid"/>
        <createIndex tableName="product_lifecycle" indexName="idx_product_lifecycle_company">
            <column name="company_id"/>
        </createIndex>
        <createIndex tableName="product_lifecycle" indexName="idx_product_lifecycle_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="product_lifecycle" indexName="idx_product_lifecycle_stage">
            <column name="lifecycle_stage"/>
        </createIndex>
    </changeSet>

    <changeSet id="2026_05_18_create_product_lifecycle_child_tables" author="Codex">
        <createTable tableName="product_lifecycle_attachments">
            <column name="product_lifecycle_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="type" type="VARCHAR(255)"/>
            <column name="size" type="VARCHAR(255)"/>
            <column name="updated_at" type="VARCHAR(255)"/>
            <column name="url" type="VARCHAR(1000)"/>
        </createTable>
        <addPrimaryKey tableName="product_lifecycle_attachments"
                       columnNames="product_lifecycle_id, sort_order"
                       constraintName="pk_product_lifecycle_attachments"/>
        <addForeignKeyConstraint baseTableName="product_lifecycle_attachments" baseColumnNames="product_lifecycle_id"
                                 constraintName="fk_pl_attachments_product" referencedTableName="product_lifecycle"
                                 referencedColumnNames="id" onDelete="CASCADE"/>

        <createTable tableName="product_lifecycle_master_log">
            <column name="product_lifecycle_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="label" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="timestamp" type="VARCHAR(255)"/>
            <column name="owner" type="VARCHAR(255)"/>
        </createTable>
        <addPrimaryKey tableName="product_lifecycle_master_log"
                       columnNames="product_lifecycle_id, sort_order"
                       constraintName="pk_product_lifecycle_master_log"/>
        <addForeignKeyConstraint baseTableName="product_lifecycle_master_log" baseColumnNames="product_lifecycle_id"
                                 constraintName="fk_pl_master_log_product" referencedTableName="product_lifecycle"
                                 referencedColumnNames="id" onDelete="CASCADE"/>

        <createTable tableName="product_lifecycle_logistics_trail">
            <column name="product_lifecycle_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="label" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="timestamp" type="VARCHAR(255)"/>
            <column name="owner" type="VARCHAR(255)"/>
        </createTable>
        <addPrimaryKey tableName="product_lifecycle_logistics_trail"
                       columnNames="product_lifecycle_id, sort_order"
                       constraintName="pk_product_lifecycle_logistics_trail"/>
        <addForeignKeyConstraint baseTableName="product_lifecycle_logistics_trail" baseColumnNames="product_lifecycle_id"
                                 constraintName="fk_pl_logistics_product" referencedTableName="product_lifecycle"
                                 referencedColumnNames="id" onDelete="CASCADE"/>

        <createTable tableName="product_lifecycle_maintenance_history">
            <column name="product_lifecycle_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="label" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="timestamp" type="VARCHAR(255)"/>
            <column name="owner" type="VARCHAR(255)"/>
        </createTable>
        <addPrimaryKey tableName="product_lifecycle_maintenance_history"
                       columnNames="product_lifecycle_id, sort_order"
                       constraintName="pk_product_lifecycle_maintenance_history"/>
        <addForeignKeyConstraint baseTableName="product_lifecycle_maintenance_history" baseColumnNames="product_lifecycle_id"
                                 constraintName="fk_pl_maintenance_product" referencedTableName="product_lifecycle"
                                 referencedColumnNames="id" onDelete="CASCADE"/>

        <createTable tableName="product_lifecycle_documents">
            <column name="product_lifecycle_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="document_id" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(255)"/>
            <column name="category" type="VARCHAR(255)"/>
            <column name="owner" type="VARCHAR(255)"/>
            <column name="updated_at" type="VARCHAR(255)"/>
        </createTable>
        <addPrimaryKey tableName="product_lifecycle_documents"
                       columnNames="product_lifecycle_id, sort_order"
                       constraintName="pk_product_lifecycle_documents"/>
        <addForeignKeyConstraint baseTableName="product_lifecycle_documents" baseColumnNames="product_lifecycle_id"
                                 constraintName="fk_pl_documents_product" referencedTableName="product_lifecycle"
                                 referencedColumnNames="id" onDelete="CASCADE"/>

        <createTable tableName="product_lifecycle_audit_trail">
            <column name="product_lifecycle_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="label" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="timestamp" type="VARCHAR(255)"/>
            <column name="owner" type="VARCHAR(255)"/>
        </createTable>
        <addPrimaryKey tableName="product_lifecycle_audit_trail"
                       columnNames="product_lifecycle_id, sort_order"
                       constraintName="pk_product_lifecycle_audit_trail"/>
        <addForeignKeyConstraint baseTableName="product_lifecycle_audit_trail" baseColumnNames="product_lifecycle_id"
                                 constraintName="fk_pl_audit_product" referencedTableName="product_lifecycle"
                                 referencedColumnNames="id" onDelete="CASCADE"/>

        <createTable tableName="product_lifecycle_digital_twin_metrics">
            <column name="product_lifecycle_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="label" type="VARCHAR(255)"/>
            <column name="value" type="VARCHAR(255)"/>
            <column name="metric_status" type="VARCHAR(255)"/>
        </createTable>
        <addPrimaryKey tableName="product_lifecycle_digital_twin_metrics"
                       columnNames="product_lifecycle_id, sort_order"
                       constraintName="pk_product_lifecycle_digital_twin_metrics"/>
        <addForeignKeyConstraint baseTableName="product_lifecycle_digital_twin_metrics" baseColumnNames="product_lifecycle_id"
                                 constraintName="fk_pl_metrics_product" referencedTableName="product_lifecycle"
                                 referencedColumnNames="id" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="2026_05_18_create_product_lifecycle_sequence" author="Codex">
        <createSequence sequenceName="product_lifecycle_seq" startValue="1" incrementBy="50"/>
    </changeSet>
</databaseChangeLog>
