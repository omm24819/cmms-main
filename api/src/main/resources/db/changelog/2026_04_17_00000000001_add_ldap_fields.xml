<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="add_ldap_fields" author="system">
        <addColumn tableName="own_user">
            <column name="ldap_id" type="varchar(255)">
                <constraints nullable="true" unique="true"/>
            </column>
        </addColumn>
        <addColumn tableName="company">
            <column name="ldap_domain" type="varchar(255)">
                <constraints nullable="true" unique="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1776687453582-1" author="Ibrahima G. Coulibaly">
        <dropColumn tableName="own_user" columnName="ldap_id"/>
    </changeSet>
</databaseChangeLog>
